// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS TABLE - PRIVATE DATA
// This table stores sensitive user information that should NEVER be exposed
// to the frontend or other users.
// ============================================================================

model User {
  id        String     @id @default(uuid()) @db.Uuid
  email     String     @unique
  passwordHash String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  publicProfile PublicProfile?
  sessions      Session[]
  accounts      Account[]
  verificationTokens VerificationToken[]

  @@map("users")
}

// ============================================================================
// PUBLIC PROFILES TABLE - PUBLIC DATA
// This table stores only information that can be safely exposed to other users.
// The real identity (email, ID) is never shown here.
// ============================================================================

model PublicProfile {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  alias      String   @unique // e.g., "SilentWolf", "MidnightCoder"
  avatarSeed String   // Seed for DiceBear avatar generation
  bio        String?  @db.Text // Optional bio (Phase 2+)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("public_profiles")
}

// ============================================================================
// AUTH.JS SCHEMA TABLES
// Required for Auth.js session and token management
// ============================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?  @db.Uuid

  @@unique([identifier, token])
  @@map("verification_tokens")
}

